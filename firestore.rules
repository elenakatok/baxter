rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // The instance doc itself carries only non-sensitive class state: current_round
    // (day-2 round pointer), the finalized markers, and game_instance_id. Any authenticated
    // participant OR the instructor may read it so a student stuck on their round-1 results
    // can detect the round advance and re-route to day-2 re-attendance (Slice 1 day-2 fix),
    // and the instructor dashboard can read the round pointer + round2_begun_at. Sensitive
    // data (the attendance code, the game config) lives in separately-denied subcollections.
    // Mirrors the existing groups rule's "any authenticated user may read" posture.
    match /game_instances/{instanceId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /game_instances/{instanceId}/participants/{participantId} {
      // Students can read their own record.
      allow read: if request.auth != null && request.auth.uid == participantId;

      // Students can update their own display_name and any prep answer field.
      // Uses a blocklist rather than an allowlist so the question editor can
      // introduce new field names (e.g. prep_abc123) without a rules redeploy.
      // Protected fields (role, scores, group assignment, timestamps) may not
      // be touched by a direct client write; create and delete remain denied.
      allow update: if request.auth != null
        && request.auth.uid == participantId
        && !request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['role', 'group_id', 'raw_score', 'normalized_score',
                      'knowledge_check_score', 'knowledge_check_attempts',
                      'prep_status', 'prep_completed_at', 'debrief_initial_offer',
                      'finalized_at', 'attendance_confirmed_at', 'confirmed_ready_at',
                      'is_lead', 'participant_id', 'game_instance_id', 'participant_late']);
    }

    // role_counts is an internal balancing counter — backend only.
    match /game_instances/{instanceId}/role_counts/{doc} {
      allow read, write: if false;
    }

    // Game config (PDF URLs, etc.) is backend-only.
    // Clients get only their role's private URL via the getInfoUrls Cloud Function,
    // which never exposes the other role's URL.
    match /game_instances/{instanceId}/config/{doc} {
      allow read, write: if false;
    }

    // Groups are written by the Cloud Function; any authenticated participant
    // can read them (group contents are not sensitive — names are already
    // visible to the instructor).
    match /game_instances/{instanceId}/groups/{groupId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Default deny for everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
